# --- Voice (Gradium) ---
GRADIUM_API_KEY=grd_replace_me

# --- LLM (Hybrid: Groq Llama via OpenAI-compatible endpoint) ---
LLM_API_KEY=gsk_replace_me
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# --- Qontext backend ---
# If qontext-api is running locally, point here. Otherwise the mock JSON is used.
QONTEXT_API_URL=http://localhost:8080
QONTEXT_USE_MOCK=1

# --- Demo behavior ---
DEMO_LANGUAGE=en
DEMO_VOICE_ID=YTpq7expH9539ERJ

# --- Discord bot (optional second entry point; see DISCORD_SETUP.md) ---
# Put the real token in .env.local, not here.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_IDLE_SECONDS=45
DISCORD_MAX_CALL_SECONDS=600
